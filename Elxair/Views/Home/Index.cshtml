<section class="elx-section elx-section-nude">
    <div class="elx-eyebrow">Why Choose Us</div>
    <h2 class="elx-section-title" style="color:#2c1712;">The Elxair Promise</h2>

    <div class="row g-4 text-center">
        @foreach (var item in new[] {
            new { Icon = "bi-droplet-half", Title = "Sample Sizes",   Desc = "Try before you commit — from just 3ml at 50 EGP." },
            new { Icon = "bi-shield-check", Title = "Authentic Only", Desc = "Every fragrance is carefully sourced and verified." },
            new { Icon = "bi-box-seam",     Title = "Gift Packaging", Desc = "Beautiful packaging ready for gifting on every order." },
            new { Icon = "bi-truck",        Title = "Fast Delivery",  Desc = "Quick local shipping across Egypt." },
        })
        {
            <div class="col-lg-3 col-md-6">
                <i class="bi @item.Icon" style="font-size:1.8rem;color:var(--rose-2);display:block;margin-bottom:14px;"></i>
                <h5 style="font-family:'Playfair Display',serif;font-size:1.05rem;color:#2c1712;margin-bottom:8px;font-weight:500;">@item.Title</h5>
                <p style="font-size:0.85rem;color:#5c3d35;line-height:1.8;font-weight:300;">@item.Desc</p>
            </div>
        }
    </div>
</section>