@model IEnumerable<Elxair.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<section class="elx-section">
    <div class="elx-eyebrow">Administration</div>
    <h2 class="elx-section-title" style="color:#2c1712;">Customer Orders</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center" style="padding:50px 0;">
            <p style="color:#8a6056;">No orders found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="elx-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>User</th>
                        <th>Status</th>
                        <th>Total Items</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td>@o.Id</td>
                            <td>@(o.User != null ? o.User.Name : "Unknown")</td>
                            <td>@o.Status</td>
                            <td>@(o.Items != null ? o.Items.Count : 0)</td>
                            <td>
                                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                    <a class="btn-elx-outline"
                                           asp-action="UpdateOrderStatus"
                                           asp-route-orderId="@o.Id"
                                           asp-route-status="Shipped">
                                        Mark Shipped
                                    </a>

                                    <a class="btn-elx-outline"
                                           asp-action="UpdateOrderStatus"
                                           asp-route-orderId="@o.Id"
                                           asp-route-status="Delivered">
                                        Mark Delivered
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>