@model IEnumerable<Elxair.Models.Perfume>

@{
    ViewData["Title"] = "Manage Products";
}

<section class="elx-section">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;margin-bottom:28px;">
        <div>
            <div class="elx-eyebrow" style="justify-content:flex-start;">Administration</div>
            <h2 class="elx-section-title" style="text-align:left;margin-bottom:0;color:#2c1712;">Manage Perfumes</h2>
        </div>

        <a class="btn-elx-outline" asp-controller="Admin" asp-action="CreatePerfume">
            Add New Perfume
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center" style="padding:50px 0;">
            <p style="color:#8a6056;">No perfumes found in the database.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="elx-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Brand</th>
                        <th>Sizes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>
                                <img src="@p.ImageUrl" alt="@p.Name" style="width:70px;height:70px;object-fit:cover;border-radius:6px;" />
                            </td>
                            <td>@p.Name</td>
                            <td>@p.Brand</td>
                            <td>@(p.Sizes != null ? p.Sizes.Count : 0)</td>
                            <td>
                                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                    <a class="btn-elx-outline" asp-action="EditPerfume" asp-route-id="@p.Id">Edit</a>
                                    <a class="btn-elx-outline" asp-action="AddPerfumeSize" asp-route-perfumeId="@p.Id">Add Size</a>
                                    <a class="btn-elx-outline" asp-action="DeletePerfume" asp-route-id="@p.Id">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>