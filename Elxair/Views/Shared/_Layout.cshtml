<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elxair Perfume Store</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

    <style>
        :root {
            --blush: #fdf8f4;
            --rose: #e8c4c0;
            --rose-2: #d4958e;
            --rose-3: #8f5751;
            --gold: #c9a46b;
            --gold-2: #e8d4b0;
            --gold-3: #f8efe2;
            --nude: #f4ebe4;
            --warm: #ede0d8;
            --brown: #3c221c;
            --brown-2: #6b4a42;
            --brown-3: #b89088;
            --border: #e8d4cc;
            --border-2: #f0e2da;
            --card-bg: #fffaf8;
            --white: #ffffff;
        }

        html {
            scroll-behavior: smooth;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            background-color: var(--blush);
            color: var(--brown);
            font-family: 'DM Sans', sans-serif;
            font-weight: 300;
            line-height: 1.7;
            margin: 0;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--blush);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--rose);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--rose-2);
        }

        .elx-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 56px;
            background: rgba(253, 248, 244, 0.95);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .elx-brand {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 600;
            letter-spacing: 6px;
            color: #6a3b35 !important;
            text-decoration: none;
            text-transform: uppercase;
            transition: color 0.2s;
        }

        .elx-brand:hover {
            color: var(--rose-3) !important;
        }

        .elx-nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .elx-nav-links a {
            color: var(--brown-2);
            font-size: 0.78rem;
            letter-spacing: 2px;
            text-decoration: none;
            text-transform: uppercase;
            font-weight: 500;
            transition: color 0.2s;
            position: relative;
            padding-bottom: 4px;
        }

        .elx-nav-links a::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 0;
            height: 1px;
            background: var(--rose-3);
            transition: width 0.25s ease;
        }

        .elx-nav-links a:hover,
        .elx-nav-links a.active {
            color: var(--rose-3);
        }

        .elx-nav-links a:hover::after,
        .elx-nav-links a.active::after {
            width: 100%;
        }

        .elx-nav-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-elx-outline {
            border: 1px solid var(--rose);
            color: var(--rose-3);
            background: transparent;
            padding: 10px 24px;
            font-size: 0.72rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            border-radius: 3px;
            transition: all 0.2s;
        }

        .btn-elx-outline:hover {
            background: var(--rose);
            color: var(--brown);
        }

        .btn-elx-fill {
            border: 1px solid var(--rose);
            color: var(--rose-3);
            background: transparent;
            padding: 10px 24px;
            font-size: 0.72rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            border-radius: 3px;
            transition: all 0.2s;
        }

        .btn-elx-fill:hover {
            background: var(--rose);
            color: var(--brown);
        }

        .btn-elx-gold {
            border: 1px solid var(--gold);
            color: var(--brown);
            background: transparent;
            padding: 10px 24px;
            font-size: 0.72rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            border-radius: 3px;
            transition: all 0.2s;
        }

        .btn-elx-gold:hover {
            background: var(--gold-3);
            color: var(--brown);
        }

        .elx-section {
            padding: 72px 64px;
        }

        .elx-section-white {
            background: var(--white);
        }

        .elx-section-nude {
            background: var(--nude);
        }

        .elx-eyebrow {
            font-size: 0.65rem;
            letter-spacing: 4px;
            color: var(--gold);
            text-transform: uppercase;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            margin-bottom: 10px;
        }

        .elx-eyebrow::before,
        .elx-eyebrow::after {
            content: '';
            flex: 1;
            max-width: 50px;
            height: 1px;
            background: var(--border);
        }

        .elx-section-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.9rem;
            font-weight: 500;
            color: var(--brown);
            text-align: center;
            margin-bottom: 48px;
        }

        .elx-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            height: 100%;
        }

        .elx-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 48px rgba(92, 61, 53, 0.1);
        }

        .elx-card-img {
            width: 100%;
            height: 280px;
            object-fit: cover;
            background: linear-gradient(145deg, #f5e8e2, #ede0d8);
            display: block;
        }

        .elx-card-body {
            padding: 20px 22px;
        }

        .elx-card-cat {
            font-size: 0.62rem;
            letter-spacing: 3px;
            color: var(--gold);
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .elx-card-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem;
            color: var(--brown);
            margin-bottom: 10px;
            font-weight: 500;
        }

        .elx-card-price {
            font-size: 0.82rem;
            color: var(--brown-3);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .elx-card-price strong {
            color: var(--rose-3);
            font-size: 0.95rem;
        }

        .elx-sizes {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .elx-size {
            font-size: 0.62rem;
            letter-spacing: 1px;
            color: var(--brown-2);
            border: 1px solid var(--border);
            padding: 3px 9px;
            border-radius: 2px;
            transition: all 0.15s;
            background: transparent;
            font-family: 'DM Sans', sans-serif;
        }

        .elx-size:hover,
        .elx-size.active {
            background: var(--rose);
            border-color: var(--rose-2);
            color: var(--brown);
        }

        .elx-badge {
            display: inline-block;
            background: var(--gold-3);
            border: 1px solid var(--gold-2);
            color: var(--brown);
            padding: 4px 12px;
            font-size: 0.65rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            border-radius: 2px;
            font-weight: 500;
        }

        .elx-marquee {
            background: var(--gold-3);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            padding: 12px 0;
            overflow: hidden;
            white-space: nowrap;
        }

        .elx-marquee-inner {
            display: inline-block;
            animation: elx-mq 26s linear infinite;
        }

        .elx-marquee-inner:hover {
            animation-play-state: paused;
        }

        @@keyframes elx-mq {
            from { transform: translateX(0); }
            to { transform: translateX(-50%); }
        }

        .elx-marquee-item {
            display: inline-block;
            font-size: 0.65rem;
            letter-spacing: 3px;
            color: var(--brown-2);
            text-transform: uppercase;
            padding: 0 28px;
            font-weight: 500;
        }

        .elx-marquee-dot {
            color: var(--rose-3);
        }

        .elx-alert {
            border-radius: 6px;
            border: 1px solid var(--border);
            padding: 14px 20px;
            font-size: 0.88rem;
            margin-bottom: 20px;
        }

        .elx-alert-success {
            background: #fdf0ee;
            border-color: var(--rose);
            color: var(--brown);
        }

        .elx-alert-danger {
            background: #fff0f0;
            border-color: #e8a0a0;
            color: #8b2020;
        }

        .elx-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.88rem;
        }

        .elx-table th {
            font-size: 0.65rem;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--brown-3);
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            font-weight: 500;
            text-align: left;
        }

        .elx-table td {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border-2);
            color: var(--brown);
        }

        .elx-table tr:hover td {
            background: var(--blush);
        }

        .elx-label {
            font-size: 0.68rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--brown-2);
            margin-bottom: 6px;
            display: block;
            font-weight: 500;
        }

        .elx-input {
            width: 100%;
            border: 1px solid var(--border);
            background: var(--white);
            color: var(--brown);
            padding: 11px 16px;
            font-size: 0.9rem;
            font-family: 'DM Sans', sans-serif;
            border-radius: 4px;
            transition: border-color 0.2s;
            outline: none;
        }

        .elx-input:focus {
            border-color: var(--rose-2);
        }

        .elx-input::placeholder {
            color: var(--brown-3);
            font-weight: 300;
        }

        .elx-divider {
            border: none;
            border-top: 1px solid var(--border-2);
            margin: 0;
        }

        .elx-footer {
            background: var(--nude);
            border-top: 1px solid var(--border);
            padding: 56px 64px 32px;
        }

        .elx-footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem;
            letter-spacing: 4px;
            color: var(--rose-3);
            text-transform: uppercase;
            margin-bottom: 12px;
            font-weight: 500;
        }

        .elx-footer-text {
            font-size: 0.82rem;
            color: var(--brown-2);
            line-height: 1.9;
            font-weight: 300;
        }

        .elx-footer-col-title {
            font-size: 0.62rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--brown-3);
            margin-bottom: 14px;
            font-weight: 500;
        }

        .elx-footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .elx-footer-links a {
            font-size: 0.82rem;
            color: var(--brown-2);
            text-decoration: none;
            font-weight: 300;
            transition: color 0.2s;
        }

        .elx-footer-links a:hover {
            color: var(--rose-3);
        }

        .elx-footer-bottom {
            margin-top: 40px;
            padding-top: 22px;
            border-top: 1px solid var(--border-2);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .elx-footer-copy {
            font-size: 0.68rem;
            color: var(--brown-3);
            letter-spacing: 1px;
        }

        .elx-toggler {
            display: none;
            background: transparent;
            border: 1px solid var(--border);
            color: var(--rose-3);
            padding: 6px 12px;
            font-size: 1rem;
            cursor: pointer;
            border-radius: 2px;
        }

        @@media (max-width: 991px) {
            .elx-nav {
                padding: 14px 20px;
            }

            .elx-toggler {
                display: block;
            }

            .elx-nav-links,
            .elx-nav-actions {
                display: none;
            }

            .elx-nav-links.show {
                display: flex;
                flex-direction: column;
                gap: 14px;
                position: absolute;
                top: 100%;
                left: 0;
                right: 0;
                background: rgba(253, 248, 244, 0.98);
                border-bottom: 1px solid var(--border);
                padding: 24px 20px;
                z-index: 999;
            }

            .elx-nav-actions.show {
                display: flex;
                position: absolute;
                top: calc(100% + 182px);
                left: 0;
                right: 0;
                background: rgba(253, 248, 244, 0.98);
                padding: 14px 20px 20px;
                border-bottom: 1px solid var(--border);
                z-index: 999;
            }

            .elx-section {
                padding: 48px 20px;
            }

            .elx-footer {
                padding: 44px 20px 28px;
            }

            .elx-footer-bottom {
                flex-direction: column;
                gap: 8px;
                text-align: center;
            }
        }

        @@media (max-width: 576px) {
            .elx-section-title {
                font-size: 2rem;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="elx-nav">
            <a class="elx-brand" asp-controller="Home" asp-action="Index">Elxair</a>

            <button class="elx-toggler" onclick="elxToggleNav()" aria-label="Menu">
                <i class="bi bi-list"></i>
            </button>

            <ul class="elx-nav-links" id="elxLinks">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Product" asp-action="Index">Products</a></li>
                <li><a asp-controller="Cart" asp-action="Index"><i class="bi bi-bag me-1"></i>Cart</a></li>
                <li><a asp-controller="Order" asp-action="Index">Orders</a></li>
                <li><a asp-controller="Admin" asp-action="Dashboard">Admin</a></li>
            </ul>

            <div class="elx-nav-actions" id="elxActions">
                <a class="btn-elx-outline" asp-controller="Account" asp-action="Login">Login</a>
                <a class="btn-elx-fill" asp-controller="Account" asp-action="Register">Register</a>
            </div>
        </nav>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="container pt-3">
            <div class="elx-alert elx-alert-success d-flex justify-content-between align-items-center">
                <span><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</span>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="container pt-3">
            <div class="elx-alert elx-alert-danger d-flex justify-content-between align-items-center">
                <span><i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]</span>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <div class="elx-marquee" aria-hidden="true">
        <div class="elx-marquee-inner">
            @{
                var notes = new[]
                {
                    "Ultra Male", "Oud", "Le Male Elixir", "One Million", "Khamra",
                    "Yara Candy", "Marshmallow", "Coconut Vanille", "Zara Gold",
                    "Musk Roman", "Musk Pink", "Very Sexy", "Imperial Valley",
                    "Stronger With You"
                };

                foreach (var n in notes)
                {
                    <span class="elx-marquee-item">@n <span class="elx-marquee-dot">·</span></span>
                }

                foreach (var n in notes)
                {
                    <span class="elx-marquee-item">@n <span class="elx-marquee-dot">·</span></span>
                }
            }
        </div>
    </div>

    <footer class="elx-footer">
        <div class="row g-5">
            <div class="col-lg-4">
                <div class="elx-footer-brand">Elxair</div>
                <p class="elx-footer-text">
                    Rare fragrances, thoughtfully crafted.<br />
                    From 3ml samples to full 100ml bottles —<br />
                    your signature scent awaits.
                </p>
            </div>

            <div class="col-lg-2 offset-lg-1">
                <div class="elx-footer-col-title">Navigate</div>
                <ul class="elx-footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Products</a></li>
                    <li><a asp-controller="Cart" asp-action="Index">Cart</a></li>
                    <li><a asp-controller="Order" asp-action="Index">My Orders</a></li>
                </ul>
            </div>

            <div class="col-lg-2">
                <div class="elx-footer-col-title">Account</div>
                <ul class="elx-footer-links">
                    <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                    <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                    <li><a asp-controller="Admin" asp-action="Dashboard">Admin Panel</a></li>
                </ul>
            </div>

            <div class="col-lg-2">
                <div class="elx-footer-col-title">Sizes Available</div>
                <ul class="elx-footer-links">
                    <li><a href="#">3ml Sample</a></li>
                    <li><a href="#">5ml · 10ml</a></li>
                    <li><a href="#">15ml · 30ml</a></li>
                    <li><a href="#">50ml · 100ml</a></li>
                </ul>
            </div>
        </div>

        <div class="elx-footer-bottom">
            <span class="elx-footer-copy">© @DateTime.Now.Year Elxair Perfume Store. All rights reserved.</span>
            <span class="elx-footer-copy">Elegant scents · Soft luxury</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function elxToggleNav() {
            document.getElementById('elxLinks').classList.toggle('show');
            document.getElementById('elxActions').classList.toggle('show');
        }

        document.addEventListener('DOMContentLoaded', function () {
            const links = document.querySelectorAll('.elx-nav-links a');
            links.forEach(link => {
                if (link.href === window.location.href) {
                    link.classList.add('active');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>